# PHPStan configuration for the entire SoManAgent project.
#
# Covers both the backend (Symfony app) and the scripts tooling.
# The binary and all extensions live in scripts/vendor so that a single
# `php scripts/scripts-install.php` is enough to get static analysis running,
# without requiring the backend Docker environment.
#
# To run: php scripts/toolkit/phpstan.php
# To restrict scope: php scripts/toolkit/phpstan.php --scope=backend  |  php scripts/toolkit/phpstan.php --scope=scripts

includes:
    - ../scripts/vendor/phpstan/phpstan-symfony/extension.neon
    - ../scripts/vendor/phpstan/phpstan-doctrine/extension.neon
    - ../scripts/vendor/phpstan/phpstan-phpunit/extension.neon
    - ../scripts/vendor/tomasvotruba/unused-public/config/extension.neon
    - phpstan-baseline.neon

parameters:
    level: 8
    paths:
        - ../backend/src
        - ../backend/tests
        - ../scripts/src
        - ../scripts/tests/test-backlog-agent.php
    excludePaths:
        - ../scripts/src/Validation/Test/Fixture
    bootstrapFiles:
        - ../backend/vendor/autoload.php
        - ../scripts/vendor/autoload.php
    unused_public:
        methods: true
        properties: true
        constants: true
