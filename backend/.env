# ============================================================
# SoManAgent — Symfony application environment (generic defaults)
#
# This file is committed and contains safe defaults for the
# Symfony application. It is loaded by the Dotenv component
# in all environments.
#
# When running via Docker, the root .env is injected into
# containers via env_file and overrides values from this file.
# Set your real local values in the root .env (gitignored).
# ============================================================

# ── Application ──────────────────────────────────────────────
APP_ENV=dev
# Generate with: openssl rand -hex 32 — set real value in root .env
APP_SECRET=

# ── PostgreSQL database ───────────────────────────────────────
# Docker hostname: db — set real credentials in root .env
DATABASE_URL="postgresql://somanagent:secret@db:5432/somanagent?serverVersion=16&charset=utf8"

# ── Claude API ────────────────────────────────────────────────
# Set real value in root .env
CLAUDE_API_KEY=

# ── OpenAI / Codex API ────────────────────────────────────────
# Set real value in root .env
OPENAI_API_KEY=

# ── GitHub ────────────────────────────────────────────────────
# Set real value in root .env
GITHUB_TOKEN=
GITHUB_DEFAULT_ORG=

# ── GitLab (optional) ─────────────────────────────────────────
# Set real value in root .env
GITLAB_TOKEN=
GITLAB_URL=https://gitlab.com

# ── CORS (frontend dev) ───────────────────────────────────────
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'

# ── Messenger (async worker queue) ───────────────────────────
MESSENGER_TRANSPORT_DSN=redis://redis:6379/messages
MESSENGER_FAILED_DSN=redis://redis:6379/failed

# ── Mercure (realtime hub) ────────────────────────────────────
MERCURE_PUBLISH_URL=http://mercure/.well-known/mercure
# Must match the Mercure service config — set real value in root .env
MERCURE_PUBLISHER_JWT_KEY=!ChangeThisMercureHubJWTSecretKey!
MERCURE_SUBSCRIBER_JWT_KEY=!ChangeThisMercureHubJWTSecretKey!
