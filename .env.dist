# ============================================================
# SoManAgent — Local environment (docker-compose)
#
# Template for the root .env (gitignored).
# Copy it and fill in your local values: cp .env.dist .env
#
# docker-compose reads this file in two ways:
#   1. Variable substitution in docker-compose.yml (${VAR}) to
#      configure services directly (db credentials, Mercure keys…)
#   2. Injected into the php and worker containers via env_file,
#      overriding backend/.env values inside the containers.
# ============================================================

# ── Application ──────────────────────────────────────────────
APP_ENV=dev
# Generate with: openssl rand -hex 32
APP_SECRET=change_me_with_a_random_32_char_string

# ── PostgreSQL database (used by db service) ─────────────────
POSTGRES_DB=somanagent
POSTGRES_USER=somanagent
POSTGRES_PASSWORD=secret
# Must match POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB above
DATABASE_URL="postgresql://somanagent:secret@db:5432/somanagent?serverVersion=16&charset=utf8"

# ── Claude API ────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com/settings/keys
CLAUDE_API_KEY=

# ── OpenAI / Codex API ────────────────────────────────────────
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── GitHub ────────────────────────────────────────────────────
# Create a token at: https://github.com/settings/tokens (needs repo scope)
# Also read by php scripts/github.php for GitHub API operations.
GITHUB_TOKEN=
GITHUB_DEFAULT_ORG=

# ── GitLab (optional) ─────────────────────────────────────────
# Create a token at: https://gitlab.com/-/profile/personal_access_tokens (needs api scope)
GITLAB_TOKEN=
GITLAB_URL=https://gitlab.com

# ── CORS (frontend dev) ───────────────────────────────────────
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'

# ── Routing ───────────────────────────────────────────────────
# Used by Symfony when generating absolute URLs from CLI contexts.
DEFAULT_URI=http://localhost

# ── Messenger (async worker queue) ───────────────────────────
MESSENGER_TRANSPORT_DSN=redis://redis:6379/messages
MESSENGER_FAILED_DSN=redis://redis:6379/failed

# ── Mercure (realtime hub, used by mercure service) ───────────
MERCURE_PUBLISH_URL=http://mercure/.well-known/mercure
MERCURE_PUBLISHER_JWT_KEY=!ChangeThisMercureHubJWTSecretKey!
MERCURE_SUBSCRIBER_JWT_KEY=!ChangeThisMercureHubJWTSecretKey!
