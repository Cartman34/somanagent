# ============================================================
# SoManAgent — .env.local template
#
# Copy this file to .env.local and fill in your local values.
# .env.local is gitignored and overrides .env for your machine.
#
#   cp .env.local.dist .env.local
# ============================================================

# ── Application ──────────────────────────────────────────────
# Generate with: openssl rand -hex 32
APP_SECRET=change_me_with_a_random_32_char_string

# ── Claude API ────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com/settings/keys
CLAUDE_API_KEY=

# ── OpenAI / Codex API ────────────────────────────────────────
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── GitHub (optional) ─────────────────────────────────────────
# Create a token at: https://github.com/settings/tokens (needs repo scope)
GITHUB_TOKEN=
GITHUB_DEFAULT_ORG=

# ── GitLab (optional) ─────────────────────────────────────────
# Create a token at: https://gitlab.com/-/profile/personal_access_tokens (needs api scope)
GITLAB_TOKEN=
GITLAB_URL=https://gitlab.com
