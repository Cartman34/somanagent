{
    "name": "sowapps/somanagent-scripts",
    "type": "project",
    "repositories": [
        {
            "type": "path",
            "url": "../../web-toolkit",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../../web-backlog",
            "options": {
                "symlink": true
            }
        }
    ],
    "require": {
        "sowapps/web-toolkit": "@dev",
        "sowapps/web-backlog": "@dev",
        "symfony/yaml": "^7.2",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-symfony": "^2.0",
        "phpstan/phpstan-doctrine": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "rector/rector": "^2.0"
    },
    "require-dev": {
        "tomasvotruba/unused-public": "^2.2"
    },
    "autoload": {
        "psr-4": {
            "Sowapps\\SoManAgent\\Script\\": "src/"
        }
    }
}
